{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "whisper-type",
  "version": "0.1.8",
  "identifier": "dev.rev0li.whisper-type",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "whisper-type — Settings",
        "width": 420,
        "height": 520,
        "resizable": false,
        "fullscreen": false,
        "visible": false
      },
      {
        "label": "download",
        "title": "whisper-type — Téléchargement",
        "url": "download.html",
        "width": 460,
        "height": 280,
        "resizable": false,
        "visible": false,
        "center": true,
        "alwaysOnTop": true
      },
      {
        "label": "debug",
        "title": "whisper-type — Debug Logs",
        "url": "debug.html",
        "width": 700,
        "height": 480,
        "resizable": true,
        "visible": false,
        "center": true
      },
      {
        "label": "overlay",
        "title": "",
        "url": "overlay.html",
        "width": 200,
        "height": 54,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/whisper_type"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
