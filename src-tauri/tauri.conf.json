{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "whisper-type",
  "version": "0.1.0",
  "identifier": "dev.rev0li.whisper-type",
  "build": {
    "frontendDist": "../src",
    "withGlobalTauri": true
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "whisper-type — Settings",
        "width": 420,
        "height": 520,
        "resizable": false,
        "fullscreen": false,
        "visible": false
      },
      {
        "label": "overlay",
        "title": "",
        "url": "overlay.html",
        "width": 200,
        "height": 54,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
